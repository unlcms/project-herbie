@@ -0,0 +1,55 @@
+<?php
+
+/**
+ * @file
+ *  Helper module for the Views Data Export tests.
+ */
+
+use Drupal\Core\Database\Query\AlterableInterface;
+use Drupal\views\Plugin\views\query\QueryPluginBase;
+use Drupal\views\ViewExecutable;
+
+/**
+ * Implements hook_views_query_alter().
+ *
+ * To check that metadata is not lost by VDE we tag a query and add metadata to
+ * it. This metadata can then later be interrogated via a hook_query_TAG_alter
+ * using that tag.
+ *
+ * @see views_data_export_test_query_views_data_export_test_add_metadata_alter
+ * @see \Drupal\Tests\views_data_export\Functional\ViewsDataExportBatchTest::testBatchQueryMetadata
+ */
+function views_data_export_test_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
+  // Only add metadata when we opt in.
+  if (!\Drupal::state()->get('views_data_export_test.add_metadata', FALSE)) {
+    return;
+  }
+
+  // Use this query tag to retrieve metadata from later in the test.
+  $query->addTag('views_data_export_test_add_metadata');
+
+  // Build the Views query already so we can access the DB query.
+  $query->build($view);
+  $view->built = TRUE;
+
+  // Add metadata.
+  $query = $view->build_info['query'];
+  $query->addMetaData('views_data_export_test.metadata', 'foo');
+  $countQuery = $view->build_info['count_query'];
+  $countQuery->addMetaData('views_data_export_test.metadata', 'foo');
+}
+
+/**
+ * Implements hook_query_TAG_alter().
+ *
+ * The tag views_data_export_test_add_metadata is added in conjunction with
+ * metadata in views_data_export_test_views_query_alter. In order to assert on
+ * the available metadata in a test we persist it in state.
+ *
+ * @see \Drupal\Tests\views_data_export\Functional\ViewsDataExportBatchTest::testBatchQueryMetadata
+ */
+function views_data_export_test_query_views_data_export_test_add_metadata_alter(AlterableInterface $query): void {
+  $observedMetadata = \Drupal::state()->get('views_data_export_test.observed_metadata', []);
+  $observedMetadata[] = $query->getMetaData('views_data_export_test.metadata');
+  \Drupal::state()->set('views_data_export_test.observed_metadata', $observedMetadata);
+}
