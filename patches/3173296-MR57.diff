+  /**
+   * Test VDE SQL views with batch do not result on metadata being lost.
+   */
+  public function testBatchQueryMetadata() {
+    $observedMetadata = \Drupal::state()->get('views_data_export_test.observed_metadata');
+    $this->assertNull($observedMetadata);
+
+    // Opt in to collecting metadata.
+    // @see views_data_export_test_views_query_alter.
+    \Drupal::state()->set('views_data_export_test.add_metadata', TRUE);
+
+    // Access the view that will trigger the batch process.
+    $this->drupalGet('views_data_export/test_1');
+
+    // Check the metadata that was found on the query.
+    // @see views_data_export_test_query_views_data_export_test_add_metadata_alter.
+    $observedMetadata = \Drupal::state()->get('views_data_export_test.observed_metadata');
+    $this->assertNotContains(NULL, $observedMetadata, 'Metadata was missing during query alter');
+    $this->assertContains('foo', $observedMetadata, 'Expected metadata was not found during query alter');
+  }
